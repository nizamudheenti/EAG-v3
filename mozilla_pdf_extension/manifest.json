{
  "manifest_version": 3,
  "name": "Webpage to PDF Converter",
  "version": "1.0",
  "description": "Reads the current website and converts it entirely into a downloaded PDF.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "pdf-converter@student-assignment.com",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save as PDF"
  }
}
